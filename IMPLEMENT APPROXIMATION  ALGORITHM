AIM:
To implement an Approximation Algorithm for the Vertex Cover Problem in C, which selects edges greedily to cover all vertices, ensuring the solution is at most twice the size of the optimal cover.

ALGORITHM:
Input a graph with n vertices and m edges.
Initialize all vertices as uncovered.
While there are uncovered edges:
Pick an arbitrary uncovered edge (u, v).
Add both u and v to the vertex cover.
Mark all edges incident to u or v as covered.
Return the set of chosen vertices as the approximate vertex cover.

C PROGRAM:

#include <stdio.h>
#include <stdbool.h>
#define MAX 20
int main() {
    int n, m;
    printf("Enter number of vertices: ");
    scanf("%d", &n);
    printf("Enter number of edges: ");
    scanf("%d", &m);
    int edges[MAX][2];
    printf("Enter edges (u v):\n");
    for (int i = 0; i < m; i++) {
        scanf("%d %d", &edges[i][0], &edges[i][1]);
    }
    bool covered[m];
    for (int i = 0; i < m; i++) covered[i] = false;
    bool vertexCover[n];
    for (int i = 0; i < n; i++) vertexCover[i] = false;
    for (int i = 0; i < m; i++) {
        if (!covered[i]) {
            int u = edges[i][0];
            int v = edges[i][1];
            vertexCover[u] = true;
            vertexCover[v] = true;
            for (int j = 0; j < m; j++) {
                if (edges[j][0] == u || edges[j][1] == u ||
                    edges[j][0] == v || edges[j][1] == v) {
                    covered[j] = true;
                }
            }
        }
    }
    printf("\nApproximate Vertex Cover:\n");
    for (int i = 0; i < n; i++) {
        if (vertexCover[i]) {
            printf("Vertex %d\n", i);
        }
    }
    return 0;
}

