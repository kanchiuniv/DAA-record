AIM:
To implement the Shortest Path Algorithm in C using Dijkstra’s Algorithm, which finds the shortest path from a source vertex to all other vertices in a weighted graph.

ALGORITHM:(Dijkstra’s)
Initialize distances from the source to all vertices as infinity, except the source itself (distance = 0).
Mark all vertices as unvisited.
Select the unvisited vertex with the smallest distance.
Update the distances of its neighboring vertices.
Mark the selected vertex as visited.
Repeat until all vertices are visited or shortest paths are found.

C PROGRAM:(Dijkstra’s Algorithm)

#include <stdio.h>
#define INF 999999
void dijkstra(int graph[10][10], int n, int start) {
    int dist[10], visited[10], count, u, v, minDist;
    for (int i = 0; i < n; i++) {
        dist[i] = INF;
        visited[i] = 0;
    }
    dist[start] = 0;
    for (count = 0; count < n - 1; count++) {
        minDist = INF;
        u = -1;
for (int i = 0; i < n; i++) {
            if (!visited[i] && dist[i] < minDist) {
                minDist = dist[i];
                u = i;
            }
        }
        if (u == -1) break; // no vertex found
        visited[u] = 1;
        for (v = 0; v < n; v++) {
            if (!visited[v] && graph[u][v] && dist[u] + graph[u][v] < dist[v]) {
                dist[v] = dist[u] + graph[u][v];
            }
        }
    }
    printf("\nShortest distances from source vertex %d:\n", start);
    for (int i = 0; i < n; i++) {
        printf("To vertex %d: %d\n", i, dist[i]);
    }
}
int main() {
    int n, start;
    printf("Enter number of vertices: ");
    scanf("%d", &n);
    int graph[10][10];
    printf("Enter adjacency matrix (0 if no edge):\n");
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &graph[i][j]);
        }
    }
    printf("Enter source vertex: ");
    scanf("%d", &start);
    dijkstra(graph, n, start);
    return 0;
}

